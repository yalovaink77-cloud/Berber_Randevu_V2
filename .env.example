# ─── Uygulama ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# "Arkadaşına öner" paylaşım linki (boşsa panel adresi kullanılır)
# REFERRAL_URL=https://ornek.com
# APP_NAME=Akıllı Berber
# Production'da: ALLOWED_ORIGINS=https://YOUR_DOMAIN.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Veritabanı ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/berber_randevu
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=BURAYA_EN_AZ_32_KARAKTER_GUCLU_BIR_SECRET_GIR
JWT_EXPIRES_IN=7d

# ─── AI Provider (en az birini doldur) ───────────────────────────────────────
GEMINI_API_KEY=
META_AI_API_KEY=
META_AI_BASE_URL=https://api.llama.com/compat/v1
META_AI_MODEL=Llama-4-Maverick-17B-128E-Instruct
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# AI ayarları
AI_PROVIDER=auto
AI_REQUEST_TIMEOUT_MS=30000
AI_CONVERSATION_HISTORY_LIMIT=4
AI_HEURISTIC_REQUEST_PARSING=true
AI_HEURISTIC_FEEDBACK_PARSING=true
AI_SUMMARY_WITH_MODEL=false

# ─── WhatsApp / Meta ─────────────────────────────────────────────────────────
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=BURAYA_RASTGELE_BIR_STRING_GIR
# Production'da zorunlu — boş bırakılırsa sunucu başlamaz
META_APP_SECRET=BURAYA_META_APP_SECRET_GIR

# ─── Berber Kaydı ────────────────────────────────────────────────────────────
# Production'da barber kaydını kapat
ALLOW_BARBER_REGISTRATION=false

# ─── İş Saatleri ─────────────────────────────────────────────────────────────
# Berber profil ayarlarıyla uyumlu olmalı (workHours.start / workHours.end)
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=20

# ─── Demo (sadece geliştirme ortamında) ──────────────────────────────────────
# Gerçek kullanıcı bilgileri buraya yazılmamalı
# DEMO_BARBER_PASSWORD en az 8 karakter olmalı
DEMO_BARBER_PHONE=+905551112233
DEMO_BARBER_PASSWORD=GUCLU_BIR_SIFRE_GIR

# ─── Mobil uygulama (cevapsız arama köprüsü) ───────────────────────────────
# Üretimde güçlü rastgele bir anahtar kullanın
DEVICE_API_KEY=
